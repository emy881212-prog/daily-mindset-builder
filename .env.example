# The app is configured for PayPal Sandbox only while testing.
PAYPAL_ENV=sandbox
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=

# Keep Live checkout disabled. Turn on only the Sandbox switch when ready to test.
PAYPAL_CHECKOUT_ENABLED=false
PAYPAL_SANDBOX_CHECKOUT_ENABLED=false

# Create six recurring PayPal plans, then paste their IDs here.
PAYPAL_PLAN_STANDARD_MONTHLY=
PAYPAL_PLAN_STANDARD_YEARLY=
PAYPAL_PLAN_PREMIUM_MONTHLY=
PAYPAL_PLAN_PREMIUM_YEARLY=
PAYPAL_PLAN_PRO_MONTHLY=
PAYPAL_PLAN_PRO_YEARLY=

# Permanent Neon Postgres connection. Keep this server-side and sensitive.
DATABASE_URL=
DATABASE_POOL_MAX=3

# Transactional email for verification and password resets.
RESEND_API_KEY=
AUTH_EMAIL_FROM=Daily Mindset Builder <account@your-verified-domain.com>

APP_URL=http://localhost:8765
PUBLIC_APP_URL=http://localhost:8765/daily-mindset-builder
PORT=8765
